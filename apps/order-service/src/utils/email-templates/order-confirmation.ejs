<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmation</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f1f5f9;
            -webkit-font-smoothing: antialiased;
        }

        table {
            border-spacing: 0;
            width: 100%;
        }

        td {
            padding: 0;
        }

        .wrapper {
            width: 100%;
            table-layout: fixed;
            background-color: #f1f5f9;
            padding-bottom: 40px;
        }

        .main {
            background-color: #ffffff;
            margin: 0 auto;
            width: 100%;
            max-width: 600px;
            border-spacing: 0;
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        }

        .header {
            background: linear-gradient(135deg, #47718F 0%, #365870 100%);
            padding: 60px 40px;
            text-align: center;
        }

        .logo {
            font-size: 32px;
            font-weight: 900;
            color: #ffffff;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .hero-text {
            color: #ffffff;
            font-size: 20px;
            font-weight: 700;
            margin-top: 15px;
            opacity: 0.9;
        }

        .content {
            padding: 50px 40px;
        }

        .greeting {
            font-size: 24px;
            font-weight: 900;
            color: #0f172a;
            margin-bottom: 15px;
        }

        .message {
            font-size: 16px;
            color: #64748b;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .order-card {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 30px;
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 12px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #47718F;
            margin-bottom: 25px;
        }

        .item {
            padding: 20px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .item:last-child {
            border-bottom: none;
        }

        .item-name {
            font-size: 15px;
            font-weight: 700;
            color: #1e293b;
        }

        .item-meta {
            font-size: 12px;
            font-weight: 700;
            color: #94a3b8;
            margin-top: 5px;
        }

        .item-price {
            font-size: 15px;
            font-weight: 900;
            color: #47718F;
            text-align: right;
        }

        .total-section {
            margin-top: 25px;
            padding-top: 25px;
            border-top: 2px solid #e2e8f0;
        }

        .total-label {
            font-size: 14px;
            font-weight: 900;
            color: #64748b;
            text-transform: uppercase;
        }

        .total-value {
            font-size: 28px;
            font-weight: 900;
            color: #47718F;
            text-align: right;
        }

        .footer {
            text-align: center;
            padding: 0 40px 60px;
        }

        .btn {
            display: inline-block;
            background-color: #47718F;
            color: #ffffff !important;
            padding: 20px 40px;
            border-radius: 18px;
            text-decoration: none;
            font-weight: 900;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 10px 20px rgba(71, 113, 143, 0.2);
        }

        .support-text {
            font-size: 12px;
            color: #94a3b8;
            margin-top: 40px;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <center class="wrapper">
        <table class="main" role="presentation">
            <tr>
                <td class="header">
                    <div class="logo">Shop-Nex</div>
                    <div class="hero-text">Order Confirmed!</div>
                </td>
            </tr>
            <tr>
                <td class="content">
                    <div class="greeting">Hi <%= name %>,</div>
                    <div class="message">
                        Your order has been successfully placed and is now being processed by our sellers. We'll send you a tracking number as soon as your items ship!
                    </div>

                    <div class="order-card">
                        <div class="section-title">Order Summary</div>
                        <table width="100%" role="presentation">
                            <% cart.forEach(function(item) { %>
                                <tr>
                                    <td class="item">
                                        <div class="item-name"><%= item.title %></div>
                                        <div class="item-meta">Quantity: <%= item.quantity %></div>
                                    </td>
                                    <td class="item" style="vertical-align: middle;">
                                        <div class="item-price">$<%= Number(item.sale_price || item.price || 0).toFixed(2) %></div>
                                    </td>
                                </tr>
                            <% }); %>
                        </table>

                        <table width="100%" class="total-section" role="presentation">
                            <tr>
                                <td class="total-label">Grand Total</td>
                                <td class="total-value">$<%= Number(totalAmount).toFixed(2) %></td>
                            </tr>
                        </table>
                    </div>

                    <div style="text-align: center;">
                        <a href="<%= trackingUrl %>" class="btn">Track My Order</a>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="footer">
                    <div class="support-text">
                        Questions about your order? Just reply to this email.<br>
                        &copy; 2026 Shop-Nex Marketplace. All rights reserved.
                    </div>
                </td>
            </tr>
        </table>
    </center>
</body>
</html>
