{
  "name": "@eshop/order-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/order-service/src",
  "targets": {
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t eshop-order-service -f apps/order-service/Dockerfile ."
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "@eshop/order-service:build",
        "port": 0
      },
      "configurations": {
        "development": {
          "buildTarget": "@eshop/order-service:build:development"
        },
        "production": {
          "buildTarget": "@eshop/order-service:build:production"
        }
      }
    }
  }
}
